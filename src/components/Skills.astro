---
import SkillItem from "@components/elements/SkillItem.astro";
import SKILLS from "@data/skills.json";
---

<section id="skills" class="py-32 px-6" data-purpose="skills-section">
  <div class="max-w-7xl mx-auto">
    <header class="reveal-on-scroll mb-20">
      <p
        class="text-accent font-display font-bold tracking-[0.2em] uppercase text-sm mb-4"
      >
        Habilidades
      </p>
    </header>
    <article class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-3">
      {
        SKILLS.map((skill) => (
          <SkillItem
            title={skill.title}
            icon={skill.icon}
            skills={skill.skills}
          />
        ))
      }
    </article>
  </div>
</section>
