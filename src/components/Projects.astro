---
import NextJsIcon from "@icons/NextJS.astro";
import TailwindIcon from "@icons/Tailwind.astro";
import ReactIcon from "@icons/React.astro";
import JavascriptIcon from "@icons/Javascript.astro";
import AstroIcon from "@icons/Astro.astro";
import StrapiIcon from "@icons/Strapi.astro";
import PROJECTS from "../data/projects.json";

const TAG_METADATA = {
  "Next.js": {
    icon: NextJsIcon,
    class: "bg-black text-white",
  },
  "Tailwind CSS": {
    icon: TailwindIcon,
    class: "bg-[#003159] text-white",
  },
  React: {
    icon: ReactIcon,
    class: "bg-cyan-500/15 text-white",
  },
  JavaScript: {
    icon: JavascriptIcon,
    class: "bg-[#c4b00a] text-black",
  },
  Astro: {
    icon: AstroIcon,
    class: "bg-[#FF5D01] text-black",
  },
  Strapi: {
    icon: StrapiIcon,
    class: "bg-[#4945FF] text-white",
  },
} as const;

type TagMeta = {
  class: string;
  icon?: any;
};

const getTagMeta = (tag: string): TagMeta => {
  const tagInfo = TAG_METADATA[tag as keyof typeof TAG_METADATA];
  return {
    class: tagInfo?.class ?? "bg-white/5 border border-white/10 text-white",
    icon: tagInfo?.icon ?? null,
  };
};
---

<section class="pt-32 px-6" data-purpose="projects-showcase" id="projects">
  <div class="max-w-7xl mx-auto">
    <div
      class="flex flex-col md:flex-row md:items-end justify-between mb-20 gap-6"
    >
      <div class="reveal-on-scroll">
        <p
          class="text-accent font-display font-bold tracking-[0.2em] uppercase text-sm mb-4"
        >
          Proyectos Destacados
        </p>
      </div>
    </div>
    <div class="flex flex-col gap-12 md:gap-20 w-full">
      {
        PROJECTS.map(
          ({ title, description, etiquetas, enlaces, image }, index) => (
            <article
              class="project-card reveal-on-scroll group w-full"
              data-purpose="project-item"
              style={`transition-delay: ${index * 0.2}s;`}
            >
              <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
                <div class="relative overflow-hidden rounded-2xl aspect-[4/3] bg-brand-gray cursor-pointer md:col-span-1">
                  <img
                    alt={title}
                    class="project-image w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                    src={image}
                  />
                  <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
                    <a
                      href={enlaces.visitar}
                      rel="noopener noreferrer"
                      target="_blank"
                      class="px-6 py-3 bg-white text-black font-bold rounded-full transform translate-y-4 group-hover:translate-y-0 transition-transform"
                    >
                      Visitar
                    </a>
                  </div>
                </div>
                <div class="flex flex-col gap-4 md:col-span-2">
                  <div>
                    <h3 class="text-2xl md:text-3xl font-display font-bold mb-2">
                      {title}
                    </h3>
                    <p class="text-content text-lg leading-relaxed max-w-2xl">
                      {description}
                    </p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {etiquetas.tags.map((tag: string) => {
                      const meta = getTagMeta(tag);
                      const Icon = meta.icon;
                      return (
                        <span
                          class={`flex items-center gap-2 px-3 py-2 rounded-full text-sm font-medium transition-all duration-150 ${meta.class}`}
                        >
                          {Icon && <Icon class="w-4 h-4" />}
                          {tag}
                        </span>
                      );
                    })}
                  </div>
                </div>
              </div>
            </article>
          ),
        )
      }
    </div>
  </div>
</section>
