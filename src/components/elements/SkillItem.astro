---
const { title, icon, skills } = Astro.props;
const skillsList = skills.split(", ");
---

<div>
  <div class="flex items-center gap-3 mb-6">
    <span class="text-2xl"
      >{
        icon === "code"
          ? "💻"
          : icon === "dns"
            ? "🌐"
            : icon === "layers"
              ? "📚"
              : icon === "database"
                ? "🗄️"
                : icon === "account_tree"
                  ? "🌳"
                  : icon === "draw"
                    ? "🎨"
                    : "🔧"
      }</span
    >
    <h3 class="text-xl font-display font-bold text-content">
      {title}
    </h3>
  </div>
  <ul class="space-y-3">
    {
      skillsList.map((skill) => (
        <li class="flex items-start gap-3 text-content">
          <span class="text-brand-gold mt-1 flex-shrink-0">•</span>
          <span class="leading-relaxed">{skill.trim()}</span>
        </li>
      ))
    }
  </ul>
</div>
